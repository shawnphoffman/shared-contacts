{
	"name": "shared-contacts-sync-service",
	"description": "Sync service for CardDAV contacts between Radicale and PostgreSQL",
	"license": "AGPL-3.0-or-later",
	"main": "dist/index.js",
	"scripts": {
		"build": "tsc",
		"start": "node dist/index.js",
		"dev": "ts-node src/index.ts",
		"watch": "tsc --watch",
		"lint": "eslint .",
		"test": "vitest run",
		"test:unit": "vitest run --exclude '**/*.integration.test.ts'",
		"test:integration": "vitest run --include '**/*.integration.test.ts'",
		"test:watch": "vitest"
	},
	"keywords": [
		"carddav",
		"sync",
		"contacts"
	],
	"author": "",
	"dependencies": {
		"bcrypt": "^5.1.1",
		"chokidar": "^3.5.3",
		"cors": "^2.8.5",
		"dotenv": "^16.3.1",
		"express": "^4.18.2",
		"pg": "^8.11.3",
		"pino": "^10.3.1",
		"pino-http": "^11.0.0"
	},
	"devDependencies": {
		"@eslint/js": "^9.36.0",
		"@types/bcrypt": "^5.0.2",
		"@types/cors": "^2.8.17",
		"@types/express": "^4.17.21",
		"@types/node": "^20.10.5",
		"@types/pg": "^8.10.9",
		"@types/pino-http": "^5.8.4",
		"eslint": "^9.36.0",
		"pino-pretty": "^13.1.3",
		"ts-node": "^10.9.2",
		"typescript": "^5.3.3",
		"typescript-eslint": "^8.46.0",
		"vitest": "^4.1.3"
	}
}
