# Shared Contacts - Environment Variables
# Copy this file to .env and update with your values

# =============================================================================
# REQUIRED — PostgreSQL credentials used by docker-compose
# =============================================================================
POSTGRES_USER=sharedcontacts
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# =============================================================================
# DATABASE — Connection settings (auto-constructed from POSTGRES_* in Docker)
# =============================================================================
# DATABASE_URL=postgresql://user:pass@host:5432/dbname
# DATABASE_SSL=false                          # Enable SSL for PostgreSQL connection
# DATABASE_SSL_REJECT_UNAUTHORIZED=true       # Reject self-signed certificates (set false for self-signed)

# =============================================================================
# UI — Management interface settings
# =============================================================================
# UI_PORT=3030                                # Port for the management UI

# =============================================================================
# SYNC — Sync service configuration
# =============================================================================
# SYNC_INTERVAL=30000                         # Sync interval in ms (default: 30000 = 30s)
# FILE_WATCHER_DEBOUNCE_MS=2000              # File watcher debounce in ms (default: 2000)
# RADICALE_URL=http://localhost:5232          # Internal Radicale URL (used by Nitro proxy)
# SYNC_SERVICE_URL=http://localhost:3001      # Internal sync service URL (used by UI health check)
# READONLY_AUTH_SYNC_INTERVAL=30000           # Interval for syncing read-only auth (ms)

# =============================================================================
# PUBLIC URLs — Used for display on the CardDAV connection page
# =============================================================================
# If not set, URLs are derived from the current browser location
# PUBLIC_UI_URL=https://contacts.example.com
# PUBLIC_CARDDAV_URL=https://carddav.example.com

# =============================================================================
# APPLE MOBILECONFIG — Profile generation for iOS/macOS
# =============================================================================
# MOBILECONFIG_ORG=Shared Contacts           # Organization name in Apple config profile

# =============================================================================
# LOGGING
# =============================================================================
# LOG_LEVEL=info                              # Pino log level: trace, debug, info, warn, error, fatal
# NODE_ENV=production                         # Set to 'production' for JSON logs, otherwise pretty-print
